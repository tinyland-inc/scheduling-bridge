{
  "name": "@tummycrypt/scheduling-bridge",
  "version": "0.6.1",
  "description": "Backend-agnostic scheduling adapter hub with Playwright automation",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "license": "MIT",
  "homepage": "https://github.com/Jesssullivan/scheduling-bridge",
  "bugs": {
    "url": "https://github.com/Jesssullivan/scheduling-bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jesssullivan/scheduling-bridge.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-derived-artifacts.mjs",
    "prepublishOnly": "pnpm check:release-metadata && pnpm check:artifact-authority && pnpm build && pnpm check:package",
    "start": "node dist/server/handler.js",
    "dev": "tsx src/server/handler.ts",
    "test": "node scripts/run-bazel-target.mjs test //:test",
    "typecheck": "node scripts/run-bazel-target.mjs build //:typecheck",
    "docs:generate": "node scripts/generate-doc-surfaces.mjs",
    "docs:build": "pnpm docs:generate && mkdocs build --strict",
    "docs:serve": "pnpm docs:generate && mkdocs serve",
    "docs:check": "node scripts/generate-doc-surfaces.mjs --check",
    "check:artifact-authority": "node scripts/check-artifact-authority.mjs",
    "check:release-metadata": "node scripts/check-release-metadata.mjs",
    "check:package": "node scripts/check-package-surface.mjs",
    "clean": "rm -rf dist pkg",
    "paper:build": "cd docs/paper && tectonic acuity-middleware-paper.tex",
    "paper:dev": "node docs/paper/watch.mjs"
  },
  "dependencies": {
    "effect": "^3.19.14",
    "ioredis": "^5",
    "pg": "8.20.0",
    "playwright-core": "1.58.1",
    "prom-client": "^15"
  },
  "peerDependencies": {
    "@tummycrypt/scheduling-kit": "^0.9.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "8.11.6",
    "fast-check": "3.23.2",
    "ioredis-mock": "^8.13.1",
    "publint": "^0.3.18",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "effect": "^3.19.14"
    }
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  }
}
